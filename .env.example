# Copy this file to .env and fill in your own values.

# Backend email configuration
EMAIL_USER=
EMAIL_PASS=

# Google reCAPTCHA Configuration
# Frontend: Use a reCAPTCHA v2 Checkbox site key.
VITE_RECAPTCHA_SITE_KEY=

# Backend: Get Secret Key from https://www.google.com/recaptcha/admin
# NEVER expose this to the frontend. Keep it server-side only.
RECAPTCHA_SECRET=

# Backend Settings
# Render will provide PORT automatically for backend services.
BACKEND_PORT=3000
# Set this to your frontend URL when the backend is called from a deployed client.
# For local development, leave as http://localhost:5173.
CORS_ORIGIN=http://localhost:5173
# For frontend builds that call the deployed backend, set this to the backend URL.
# Example: https://your-backend-name.onrender.com
VITE_BACKEND_URL=http://localhost:3000
