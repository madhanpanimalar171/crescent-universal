# Copy this file to .env and fill in your own EmailJS values.
# Get these from https://www.emailjs.com after creating a free account:
#   1. Email Services -> Add a service (e.g. connect Gmail) -> copy the Service ID
#   2. Email Templates -> create a template with {{from_name}}, {{from_email}},
#      {{phone}} and {{message}} variables -> copy the Template ID
#   3. Account -> General -> copy the Public Key
#
# Until these are filled in, the contact form will show a friendly
# "not connected yet" message instead of trying (and failing) to send.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
